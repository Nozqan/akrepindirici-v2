<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Never back up the encrypted media DB or biometric preference flags -->
        <exclude domain="database" path="akrep_indirici.db" />
        <exclude domain="sharedpref" path="security_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="akrep_indirici.db" />
        <exclude domain="sharedpref" path="security_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
